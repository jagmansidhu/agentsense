# Copy to `.env` and fill in. Never commit the real .env.

# CLōD LLM API (OpenAI-compatible — see docs/clod_api_quick_reference.md)
CLOD_API_URL=https://api.clod.io/v1/chat/completions
CLOD_MODEL=DeepSeek V3
CLOD_API_KEY=
CLOD_TEMPERATURE=0.7
# Uncomment to cap reply length at the LLM provider (omit for provider default).
# CLOD_MAX_COMPLETION_TOKENS=1024

# Comma-separated browser origins allowed to POST the proxy (omit for "*" in dev).
# AGENTSENSE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JUDGE_MODEL=

# Greptile (code correlation)
GREPTILE_API_KEY=
GREPTILE_REPO=your-org/your-repo
GREPTILE_BRANCH=main

# OpenClaw (local alert gateway)
OPENCLAW_URL=http://127.0.0.1:18789/api
OPENCLAW_CHANNEL=telegram

# Internal service wiring
CLASSIFIER_URL=http://localhost:8001/classify

# Persistence (optional). If unset, AgentSense runs purely in-memory.
# - SQLite (zero setup):    sqlite:///./agentsense.db
# - Postgres via docker:    postgresql+psycopg://agentsense:agentsense@127.0.0.1:5432/agentsense
# DATABASE_URL=sqlite:///./agentsense.db

# Cursor transcript ingestion (used by scripts/watch_cursor_transcripts.py).
# Point this at the agent-transcripts folder for a Cursor project, e.g.:
# CURSOR_TRANSCRIPTS_DIR=/Users/you/.cursor/projects/<project-id>/agent-transcripts
# CURSOR_AGENT_NAME=Cursor Agent
